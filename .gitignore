# .gitignore - ملفات لا تحتاج إلى Version Control

# System files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.min.js
*.min.css

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache directories
.cache/
.eslintcache

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.AppleDouble
.AppleDB
._*

# Temporary files
*.tmp
*.temp

# Production build
/dist
/build

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Local history for Visual Studio Code
.history/

# Backup files
*.backup
*.bak

# Compiled files
*.pyc
*.class
*.dll

# Private files
private/
secrets/
credentials.json